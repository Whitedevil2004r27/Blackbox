{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {},
    "db:generate": {},
    "db:migrate": {
      "dependsOn": ["db:generate"]
    },
    "db:push": {},
    "db:studio": {
      "persistent": true
    },
    "realtime": {
      "persistent": true
    }
  }
}
