# ============================================================
# FreelanceX — Monorepo Environment Variables
# ============================================================

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------
DATABASE_URL=postgres://freelancex:freelancex_secret@localhost:5432/freelancex

# -----------------------------------------------------------
# Redis (Caching, Rate Limiting, Sessions)
# -----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------
# Meilisearch (Search Engine)
# -----------------------------------------------------------
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=freelancex_meili_master_key

# -----------------------------------------------------------
# API Server
# -----------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# -----------------------------------------------------------
# Lucia Auth (Session Management)
# -----------------------------------------------------------
LUCIA_SECRET_KEY=your-super-secret-lucia-key-min-32-chars-long

# -----------------------------------------------------------
# Stripe Connect (Payments)
# -----------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxx
STRIPE_PLATFORM_FEE_PERCENT=10

# -----------------------------------------------------------
# Resend (Email)
# -----------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxx
EMAIL_FROM=noreply@freelancex.dev

# -----------------------------------------------------------
# OpenAI (AI Matching, Embeddings)
# -----------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------
# Expo / Mobile
# -----------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------
# Next.js Web
# -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}

# -----------------------------------------------------------
# Security
# -----------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

